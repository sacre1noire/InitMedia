# Скопируйте в .env и подправьте под себя:
#   cp .env.example .env
#
# Для локальной разработки можно ничего не менять — дефолтов docker-compose
# хватит, чтобы поднять стек на http://localhost:5173.
# Для прода см. .env.production.

# Адрес API, который вшивается в frontend на этапе сборки
VITE_API_URL=http://localhost:8080

# Backend CORS — список origin'ов через запятую
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Секрет для подписи JWT (для прода обязательно сменить)
JWT_SECRET=local-dev-secret-change-me

# Пароль PostgreSQL (внутри docker-сети)
POSTGRES_PASSWORD=postgres
